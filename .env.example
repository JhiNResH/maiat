# Database
DATABASE_URL="file:./dev.db"

# Privy (Auth)
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# Google Gemini API
GOOGLE_GEMINI_API_KEY=""
# OR
GOOGLE_GENERATIVE_AI_API_KEY=""

# Base Chain RPC
NEXT_PUBLIC_BASE_RPC_URL="https://mainnet.base.org"

# BSC On-Chain Verification
NEXT_PUBLIC_REVIEW_REGISTRY_ADDRESS=""  # BSC Testnet contract address
BSC_RELAYER_PRIVATE_KEY=""              # BSC Testnet gas relayer wallet (legacy)

# Base On-Chain Verification (primary — used by src/lib/onchain.ts)
# Without this key, on-chain attestations (submitReviewOnChain) will silently skip.
BASE_RELAYER_PRIVATE_KEY=""             # Base mainnet/Sepolia gas relayer wallet (0x...)

# Upstash Redis (for rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
